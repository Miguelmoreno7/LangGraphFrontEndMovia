APP_ENV=production
LOG_LEVEL=INFO

# Optional: set this for managed Postgres (Supabase recommended).
# If omitted, docker-compose.yml defaults to the internal postgres service.
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# Leave unset to use internal Redis service from docker-compose.yml
# REDIS_URL=redis://redis:6379/0

QUEUE_NAME=runs:queue
API_PORT=8000
WORKER_MAX_RETRIES=2
WORKER_POLL_TIMEOUT_SECONDS=5

# Replace with your actual frontend domain(s), comma-separated if needed
CORS_ORIGINS=https://your-frontend-domain.com

# Optional, depending on your graph/tool usage
# OPENAI_API_KEY=...
