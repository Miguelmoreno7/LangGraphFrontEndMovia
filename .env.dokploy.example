APP_ENV=production
LOG_LEVEL=INFO

# Required: Supabase Postgres connection string.
# Example:
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Required by this project: enforce Supabase host and sslmode=require checks.
REQUIRE_SUPABASE_DATABASE=true

# Leave unset to use internal Redis service from docker-compose.yml
# REDIS_URL=redis://redis:6379/0

QUEUE_NAME=runs:queue
API_PORT=8000
WORKER_MAX_RETRIES=2
WORKER_POLL_TIMEOUT_SECONDS=5
AGENT_WEBHOOK_BASE_URL=https://your-client-agent-domain.com
AGENT_WEBHOOK_TIMEOUT_SECONDS=30
# AGENT_WEBHOOK_DISPATCHER_TOKEN=shared-secret-if-required

# Replace with your actual frontend domain(s), comma-separated if needed
CORS_ORIGINS=https://your-frontend-domain.com

# Optional, depending on your graph/tool usage
# OPENAI_API_KEY=...
