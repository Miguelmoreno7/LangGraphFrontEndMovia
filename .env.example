APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/langgraph_platform
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=runs:queue

API_PORT=8000
CORS_ORIGINS=*

WORKER_CONCURRENCY=1
WORKER_POLL_TIMEOUT_SECONDS=5
WORKER_MAX_RETRIES=2

# Frontend only (for local Vite dev)
VITE_API_BASE_URL=http://localhost:8000

