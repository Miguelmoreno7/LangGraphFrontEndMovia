APP_ENV=development
LOG_LEVEL=INFO

# Supabase database is required for this setup.
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres?sslmode=require
REQUIRE_SUPABASE_DATABASE=true
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=runs:queue

API_PORT=8000
CORS_ORIGINS=*

WORKER_CONCURRENCY=1
WORKER_POLL_TIMEOUT_SECONDS=5
WORKER_MAX_RETRIES=2
AGENT_WEBHOOK_BASE_URL=
AGENT_WEBHOOK_TIMEOUT_SECONDS=30
# AGENT_WEBHOOK_DISPATCHER_TOKEN=

# Frontend only (for local Vite dev)
VITE_API_BASE_URL=http://localhost:8000
